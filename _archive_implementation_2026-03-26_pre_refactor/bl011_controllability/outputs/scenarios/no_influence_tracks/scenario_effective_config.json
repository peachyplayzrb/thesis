{
  "scenario_id": "no_influence_tracks",
  "test_id": "EP-CTRL-001",
  "control_surface": "influence_tracks",
  "description": "Disable influence-track interactions while keeping all other inputs and parameters fixed.",
  "expected_effect": "profile and ranking shift away from influence-steered indie/alternative emphasis",
  "profile": {
    "effective_weight_rule": "effective_weight = preference_weight",
    "numeric_feature_columns": [
      "danceability",
      "energy",
      "valence",
      "tempo",
      "key",
      "mode",
      "popularity",
      "duration_ms"
    ],
    "top_tag_limit": 10,
    "top_genre_limit": 10,
    "top_lead_genre_limit": 10,
    "aggregation_rules": {
      "numeric": "weighted mean over numeric columns embedded in the BL-003 enriched seed table; key uses weighted circular mean on the 12-semitone wheel",
      "tags": "sum(preference_weight) over DS-001 tag labels",
      "genres": "sum(preference_weight) over DS-001 genre labels",
      "lead_genres": "sum(preference_weight)"
    },
    "include_interaction_types": [
      "history"
    ]
  },
  "retrieval": {
    "top_lead_genre_limit": 6,
    "top_tag_limit": 10,
    "top_genre_limit": 8,
    "threshold_scale": 1.0,
    "numeric_thresholds": {
      "tempo": 15.0,
      "key": 1.5,
      "mode": 0.5,
      "duration_ms": 30000.0
    },
    "keep_rule": "keep if not seed and (semantic_score >= 3 or (semantic_score >= 1 and numeric_pass_count >= 2))"
  },
  "scoring": {
    "numeric_thresholds": {
      "tempo": 15.0,
      "key": 1.5,
      "mode": 0.5,
      "duration_ms": 30000.0
    },
    "component_weights": {
      "tempo": 0.12,
      "duration_ms": 0.08,
      "key": 0.08,
      "mode": 0.07,
      "lead_genre": 0.23,
      "genre_overlap": 0.19,
      "tag_overlap": 0.23
    },
    "weight_override_component": null,
    "raw_override_value": null
  },
  "assembly": {
    "target_size": 10,
    "min_score_threshold": 0.35,
    "max_per_genre": 4,
    "max_consecutive": 2
  }
}
