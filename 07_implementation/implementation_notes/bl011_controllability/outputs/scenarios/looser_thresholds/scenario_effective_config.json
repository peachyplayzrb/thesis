      "valence": 0.15,
      "tempo": 15.0,
      "key": 1.5,
      "mode": 0.5,
      "duration_ms": 30000.0
    },
    "component_weights": {
      "danceability": 0.04,
      "energy": 0.03,
      "valence": 0.03,
      "tempo": 0.03,
      "duration_ms": 0.02,
      "key": 0.02,
      "mode": 0.01,
      "lead_genre": 0.29,
