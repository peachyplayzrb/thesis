      "valence": 0.1875,
      "tempo": 18.75,
      "key": 1.875,
      "mode": 0.625,
      "duration_ms": 37500.0
    },
    "keep_rule": "keep if not seed and (semantic_score >= 3 or (semantic_score >= 1 and numeric_pass_count >= 4))"
  },
  "scoring": {
