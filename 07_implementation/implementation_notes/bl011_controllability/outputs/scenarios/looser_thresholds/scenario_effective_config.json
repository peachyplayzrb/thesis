{
  "scenario_id": "looser_thresholds",
  "test_id": "EP-CTRL-003",
  "control_surface": "candidate_threshold",
  "description": "Loosen all numeric retrieval thresholds by multiplying them by 1.25.",
  "expected_effect": "candidate pool should expand and downstream ranking or playlist composition should change",
  "profile": {
    "effective_weight_rule": "effective_weight = preference_weight",
    "numeric_feature_columns": [
      "danceability",
      "energy",
      "valence",
      "tempo",
      "key",
      "mode",
      "popularity",
      "duration_ms"
    ],
    "top_tag_limit": 10,
    "top_genre_limit": 10,
    "top_lead_genre_limit": 10,
    "aggregation_rules": {
      "numeric": "weighted mean over numeric columns embedded in the BL-003 enriched seed table; key uses weighted circular mean on the 12-semitone wheel",
      "tags": "sum(preference_weight) over DS-001 tag labels",
      "genres": "sum(preference_weight) over DS-001 genre labels",
      "lead_genres": "sum(preference_weight)"
    },
    "include_interaction_types": [
      "history",
      "influence"
    ]
  },
  "retrieval": {
