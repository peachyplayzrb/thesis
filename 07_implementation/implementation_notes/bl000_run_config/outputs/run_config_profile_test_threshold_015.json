{
  "schema_version": "run-config-v1",
  "user_context": {
    "user_id": null
  },
  "input_scope": {
    "source_family": "spotify_api_export",
    "include_top_tracks": true,
    "top_time_ranges": [
      "short_term",
      "medium_term",
      "long_term"
    ],
    "include_saved_tracks": true,
    "saved_tracks_limit": null,
    "include_playlists": true,
    "playlists_limit": null,
    "playlist_items_per_playlist_limit": null,
    "include_recently_played": true,
    "recently_played_limit": 50
  },
  "interaction_scope": {
    "include_interaction_types": [
      "history",
      "influence"
    ]
  },
  "influence_tracks": {
    "enabled": true,
    "track_ids": [],
    "preference_weight": 1.0,
    "source": null
  },
  "seed_controls": {
    "match_rate_min_threshold": 0.15,
    "match_rate_min_threshold_comment": "Temporary profile-test threshold for low DS-001 coverage account (auto-generated)."
  },
  "profile_controls": {
    "top_tag_limit": 10,
    "top_genre_limit": 10,
    "top_lead_genre_limit": 10
  },
  "retrieval_controls": {
    "profile_top_tag_limit": 10,
    "profile_top_tag_limit_comment": "Must be <= profile_controls.top_tag_limit. Retrieval cannot request more profile tags than BL-004 produces.",
    "profile_top_genre_limit": 8,
    "profile_top_genre_limit_comment": "Must be <= profile_controls.top_genre_limit.",
    "profile_top_lead_genre_limit": 6,
    "profile_top_lead_genre_limit_comment": "Must be <= profile_controls.top_lead_genre_limit.",
    "semantic_strong_keep_score": 2,
    "semantic_min_keep_score": 1,
    "numeric_support_min_pass": 1,
    "numeric_thresholds": {
      "tempo": 20.0,
      "key": 2.0,
      "mode": 0.5,
      "duration_ms": 45000.0
    }
  },
  "scoring_controls": {
    "component_weights": {
      "tempo": 0.2,
      "duration_ms": 0.13,
      "key": 0.13,
      "mode": 0.09,
      "lead_genre": 0.17,
      "genre_overlap": 0.12,
      "tag_overlap": 0.16
    },
    "component_weights_sum_rule_comment": "Component weights must sum to 1.0 within +/-0.01 tolerance. BL-006 logs a warning if active weights are rebalanced to normalize to 1.0.",
    "numeric_thresholds": {
      "tempo": 20.0,
      "key": 2.0,
      "mode": 0.5,
      "duration_ms": 45000.0
    }
  },
  "assembly_controls": {
    "target_size": 10,
    "min_score_threshold": 0.35,
    "max_per_genre": 4,
    "max_consecutive": 2
  },
  "transparency_controls": {
    "top_contributor_limit": 3
  },
  "observability_controls": {
    "diagnostic_sample_limit": 5
  }
}
