digraph Figure_2_2_Uncertainty_Stages {
  rankdir=TB;
  graph [fontsize=10, fontname="Arial"];
  node [shape=box, style="rounded", fontsize=10, fontname="Arial"];

  A [label="Interaction Evidence\nImplicit behaviour may reflect convenience, exposure, or preference"];
  B [label="Profile Construction\nRecency, weighting, and alignment assumptions shape preference evidence"];
  C [label="Candidate Generation\nThresholds and filtering alter which items can be ranked"];
  D [label="Scoring and Ranking\nMetric choice and normalization reshape neighborhood geometry"];
  E [label="Playlist Assembly\nCoherence, diversity, novelty, and ordering objectives can interfere"];
  F [label="Explanation Layer\nPersuasive narratives may diverge from mechanism-level fidelity"];
  G [label="Observability and Reproducibility\nProcess-level traceability is needed across all prior stages"];

  A -> B -> C -> D -> E -> F -> G;
}
